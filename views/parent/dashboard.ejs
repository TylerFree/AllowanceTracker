<%- include('../partials/head', { title: 'Dashboard' }) %>
<%- include('../partials/nav') %>

<div class="container pb-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 fw-bold">Dashboard</h1>
    <div class="d-flex gap-2">
      <a href="/parent/manage" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-gear me-1"></i>Manage
      </a>
      <form action="/parent/credit-all" method="POST" class="mb-0"
            onsubmit="return confirm('Credit this week\'s allowance to ALL children now?')">
        <button type="submit" class="btn btn-success btn-sm">
          <i class="bi bi-calendar-check me-1"></i>Credit All
        </button>
      </form>
    </div>
  </div>

  <% if (children.length === 0) { %>
    <div class="card text-center py-5 border-dashed">
      <div class="card-body">
        <i class="bi bi-people text-muted" style="font-size: 3rem;"></i>
        <p class="mt-3 text-muted">No children added yet.</p>
        <a href="/parent/manage" class="btn btn-primary">Add Children</a>
      </div>
    </div>
  <% } else { %>
    <div class="row g-3">
      <% children.forEach(child => { %>
        <div class="col-12 col-sm-6 col-lg-4">
          <a href="/parent/child/<%= child.id %>" class="text-decoration-none">
            <div class="card h-100 child-card shadow-sm">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-3">
                  <div class="child-avatar">
                    <%= child.name.charAt(0).toUpperCase() %>
                  </div>
                  <span class="badge bg-light text-muted border">
                    $<%= child.weekly_amount.toFixed(2) %>/wk
                  </span>
                </div>
                <h5 class="card-title fw-bold mb-1"><%= child.name %></h5>
                <div class="mt-2">
                  <span class="balance-amount <%= child.balance >= 0 ? 'text-success' : 'text-danger' %>">
                    $<%= Math.abs(child.balance).toFixed(2) %>
                  </span>
                  <% if (child.balance < 0) { %>
                    <span class="text-danger small ms-1">(overdrawn)</span>
                  <% } %>
                </div>
                <p class="text-muted small mt-2 mb-0">
                  <i class="bi bi-arrow-right-circle me-1"></i>View transactions
                </p>
              </div>
            </div>
          </a>
        </div>
      <% }) %>
    </div>

    <div class="mt-4 p-3 bg-light rounded border text-muted small">
      <i class="bi bi-info-circle me-2"></i>
      Allowances are credited automatically every <strong>Saturday at 8:00 AM</strong>.
      Use <strong>Credit All</strong> to credit manually.
    </div>
  <% } %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
