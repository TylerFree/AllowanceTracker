<%- include('../partials/head', { title: child.name }) %>
<%- include('../partials/nav') %>

<div class="container pb-5">
  <!-- Header -->
  <div class="d-flex align-items-center gap-3 mb-4">
    <a href="/parent" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-arrow-left"></i>
    </a>
    <div class="child-avatar"><%= child.name.charAt(0).toUpperCase() %></div>
    <div>
      <h1 class="h3 mb-0 fw-bold"><%= child.name %></h1>
      <span class="text-muted small">$<%= child.weekly_amount.toFixed(2) %>/week allowance</span>
    </div>
  </div>

  <!-- Balance card -->
  <div class="card mb-4 border-0 shadow-sm <%= balance >= 0 ? 'bg-success-subtle' : 'bg-danger-subtle' %>">
    <div class="card-body py-3">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <p class="text-muted small mb-1">Current Balance</p>
          <span class="display-6 fw-bold <%= balance >= 0 ? 'text-success' : 'text-danger' %>">
            <%= balance < 0 ? '-' : '' %>$<%= Math.abs(balance).toFixed(2) %>
          </span>
        </div>
        <form action="/parent/credit-allowance/<%= child.id %>" method="POST">
          <button type="submit" class="btn btn-success btn-sm">
            <i class="bi bi-plus-circle me-1"></i>Credit Allowance
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Add transaction -->
  <div class="card mb-4 shadow-sm">
    <div class="card-header bg-white fw-semibold">
      <i class="bi bi-plus-lg me-2 text-primary"></i>Add Transaction
    </div>
    <div class="card-body">
      <form action="/parent/transaction" method="POST">
        <input type="hidden" name="child_id" value="<%= child.id %>">
        <div class="row g-3">
          <div class="col-12 col-sm-4">
            <label class="form-label small fw-medium">Type</label>
            <select name="type" class="form-select" id="txnType">
              <option value="deduction">Deduction (penalty)</option>
              <option value="payout">Payout (cash given)</option>
              <option value="allowance">Allowance (bonus)</option>
            </select>
          </div>
          <div class="col-6 col-sm-3">
            <label class="form-label small fw-medium">Amount ($)</label>
            <input type="number" name="amount" class="form-control" step="0.01" min="0.01" placeholder="0.00" required>
          </div>
          <div class="col-12 col-sm-5">
            <label class="form-label small fw-medium">Description</label>
            <input type="text" name="description" class="form-control" placeholder="e.g. Didn't do dishes">
          </div>
        </div>
        <button type="submit" class="btn btn-primary mt-3">
          <i class="bi bi-check-lg me-1"></i>Add
        </button>
      </form>
    </div>
  </div>

  <!-- Transaction history -->
  <div class="card shadow-sm">
    <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
      <span><i class="bi bi-clock-history me-2 text-secondary"></i>Transaction History</span>
      <span class="badge bg-secondary"><%= transactions.length %></span>
    </div>
    <% if (transactions.length === 0) { %>
      <div class="card-body text-center text-muted py-5">
        <i class="bi bi-inbox" style="font-size: 2rem;"></i>
        <p class="mt-2 mb-0">No transactions yet.</p>
      </div>
    <% } else { %>
      <ul class="list-group list-group-flush">
        <% transactions.forEach(txn => { %>
          <li class="list-group-item py-3">
            <div class="d-flex justify-content-between align-items-start">
              <div class="d-flex gap-3 align-items-start">
                <div class="txn-icon mt-1
                  <%= txn.type === 'allowance' ? 'text-success' :
                      txn.type === 'deduction' ? 'text-danger' : 'text-warning' %>">
                  <i class="bi bi-<%= txn.type === 'allowance' ? 'arrow-up-circle-fill' :
                                        txn.type === 'deduction' ? 'arrow-down-circle-fill' : 'cash-coin' %>"></i>
                </div>
                <div>
                  <div class="fw-medium">
                    <%= txn.description || (txn.type === 'allowance' ? 'Weekly Allowance' : txn.type.charAt(0).toUpperCase() + txn.type.slice(1)) %>
                  </div>
                  <div class="text-muted small">
                    <%= new Date(txn.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                    <% if (txn.created_by_name) { %>&nbsp;· by <%= txn.created_by_name %><% } %>
                  </div>
                </div>
              </div>
              <div class="d-flex align-items-center gap-3">
                <span class="fw-bold <%= txn.type === 'allowance' ? 'text-success' : 'text-danger' %>">
                  <%= txn.type === 'allowance' ? '+' : '-' %>$<%= txn.amount.toFixed(2) %>
                </span>
                <form action="/parent/transaction/delete" method="POST" class="mb-0"
                      onsubmit="return confirm('Delete this transaction?')">
                  <input type="hidden" name="transaction_id" value="<%= txn.id %>">
                  <input type="hidden" name="child_id" value="<%= child.id %>">
                  <button type="submit" class="btn btn-link btn-sm text-muted p-0" title="Delete">
                    <i class="bi bi-trash3"></i>
                  </button>
                </form>
              </div>
            </div>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
