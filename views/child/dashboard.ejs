<%- include('../partials/head', { title: child.name }) %>
<%- include('../partials/nav') %>

<div class="container pb-5">
  <!-- Balance -->
  <div class="text-center mb-4">
    <div class="child-avatar child-avatar-lg mx-auto mb-3">
      <%= child.name.charAt(0).toUpperCase() %>
    </div>
    <h2 class="fw-bold mb-1"><%= child.name %></h2>
    <p class="text-muted">$<%= child.weekly_amount.toFixed(2) %> per week</p>
  </div>

  <div class="card border-0 shadow-sm mb-4 <%= balance >= 0 ? 'bg-success-subtle' : 'bg-danger-subtle' %> text-center py-4">
    <p class="text-muted mb-1 small text-uppercase fw-semibold tracking-wide">My Balance</p>
    <div class="display-4 fw-bold <%= balance >= 0 ? 'text-success' : 'text-danger' %>">
      <%= balance < 0 ? '-' : '' %>$<%= Math.abs(balance).toFixed(2) %>
    </div>
    <% if (balance < 0) { %>
      <p class="text-danger small mt-1 mb-0">Overdrawn</p>
    <% } %>
  </div>

  <!-- Transaction history -->
  <div class="card shadow-sm">
    <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
      <span><i class="bi bi-clock-history me-2 text-secondary"></i>Recent Transactions</span>
      <span class="badge bg-secondary"><%= transactions.length %></span>
    </div>
    <% if (transactions.length === 0) { %>
      <div class="card-body text-center text-muted py-5">
        <i class="bi bi-inbox" style="font-size: 2rem;"></i>
        <p class="mt-2 mb-0">No transactions yet!</p>
      </div>
    <% } else { %>
      <ul class="list-group list-group-flush">
        <% transactions.forEach(txn => { %>
          <li class="list-group-item py-3">
            <div class="d-flex justify-content-between align-items-start">
              <div class="d-flex gap-3 align-items-start">
                <div class="txn-icon mt-1
                  <%= txn.type === 'allowance' ? 'text-success' :
                      txn.type === 'deduction' ? 'text-danger' : 'text-warning' %>">
                  <i class="bi bi-<%= txn.type === 'allowance' ? 'arrow-up-circle-fill' :
                                        txn.type === 'deduction' ? 'arrow-down-circle-fill' : 'cash-coin' %>
                     " style="font-size: 1.3rem;"></i>
                </div>
                <div>
                  <div class="fw-medium">
                    <%= txn.description || (txn.type === 'allowance' ? 'Weekly Allowance' :
                        txn.type === 'payout' ? 'Cash Payout' : 'Deduction') %>
                  </div>
                  <div class="text-muted small">
                    <%= new Date(txn.created_at).toLocaleDateString('en-US', {
                      weekday: 'short', month: 'short', day: 'numeric', year: 'numeric'
                    }) %>
                  </div>
                </div>
              </div>
              <span class="fw-bold fs-5 <%= txn.type === 'allowance' ? 'text-success' : 'text-danger' %>">
                <%= txn.type === 'allowance' ? '+' : '-' %>$<%= txn.amount.toFixed(2) %>
              </span>
            </div>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
